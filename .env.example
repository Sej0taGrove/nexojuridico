# ==============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==============================================================================

# Conexión a PostgreSQL (Se recomienda usar Connection Pooler si aplica: Supabase/Neon)
# Ejemplo: postgresql://postgres:password@localhost:5432/nexojuridico?schema=public
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST:PUERTO/DATABASE_NAME?schema=public"

# ==============================================================================
# CONFIGURACIÓN DE AUTENTICACIÓN (JWT)
# ==============================================================================

# Secreto para la firma de Access Tokens (Tiempos de vida cortos)
# Puedes generar uno ejecutando `openssl rand -base64 32` en tu terminal
JWT_SECRET="reemplazar_con_un_secreto_seguro_para_jwt"

# Secreto para la firma de Refresh Tokens (Tiempos de vida largos)
# Puedes generar uno ejecutando `openssl rand -base64 32` en tu terminal
JWT_REFRESH_SECRET="reemplazar_con_un_secreto_refresco_seguro"

# ==============================================================================
# TAREAS PROGRAMADAS (CRON JOBS)
# ==============================================================================

# Vercel provee esta variable automáticamente en producción.
# Para pruebas locales, defínela con cualquier valor seguro.
CRON_SECRET="reemplazar_con_un_secreto_para_el_cron"
